    "from sklearn.model_selection import train_test_split\n",
    "import os\n",
    "import shutil\n",
    "\n",
    "# Folder to save split dataset\n",
    "save_path = \"split_data\"\n",
    "\n",
    "# Create folders\n",
    "for folder in [\"train\", \"valid\", \"test\"]:\n",
    "    for category in classes:\n",
    "        os.makedirs(os.path.join(save_path, folder, category), exist_ok=True)\n",
    "\n",
    "# Split data\n",
    "for category in classes:\n",
    "\n",
    "    folder = os.path.join(data_path, category)\n",
    "    images = os.listdir(folder)\n",
    "\n",
    "    train_images, temp_images = train_test_split(\n",
    "        images,\n",
    "        test_size=0.30,\n",
    "        random_state=42\n",
    "    )\n",
    "\n",
    "    valid_images, test_images = train_test_split(\n",
    "        temp_images,\n",
    "        test_size=0.50,\n",
    "        random_state=42\n",
    "    )\n",
    "\n",
    "    for image in train_images:\n",
    "        shutil.copy(\n",
    "            os.path.join(folder, image),\n",
    "            os.path.join(save_path, \"train\", category, image)\n",
    "        )\n",
    "\n",
    "    for image in valid_images:\n",
    "        shutil.copy(\n",
    "            os.path.join(folder, image),\n",
    "            os.path.join(save_path, \"valid\", category, image)\n",
    "        )\n",
    "\n",
    "    for image in test_images:\n",
    "        shutil.copy(\n",
    "            os.path.join(folder, image),\n",
    "            os.path.join(save_path, \"test\", category, image)\n",
    "        )\n",
    "\n",
    "print(\"Dataset split completed.\")\n"
   ]
  },
